# ==============================================================================
# Print-On-Demand (POD) Store Production Environment Variable Template
# Location: Copy this file to '.env' at the VPS server root before deployment.
# ==============================================================================

# 1. Database Connections (PgBouncer and Raw Postgres Configurations)
DB_HOST=pgbouncer
DB_PORT=6432
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_PRODUCTION_POSTGRES_PASSWORD_HERE
DB_DATABASE=printing_store

# Postgres container configuration (used by compose to launch raw database service)
POSTGRES_DB=printing_store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PRODUCTION_POSTGRES_PASSWORD_HERE

# 2. Authentication Secrets
# Generate a secure secret using: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_STRING_GOES_HERE

# 3. Paymob Egyptian Payments Integration (Acceptance and HMAC Tokens)
# Paymob API Key: Obtained from Paymob Egypt Profile settings
PAYMOB_API_KEY=YOUR_PAYMOB_API_KEY_HERE
# Paymob HMAC Secret: Used to sign webhooks in acceptor integrations
PAYMOB_HMAC_SECRET=YOUR_PAYMOB_HMAC_SECRET_HERE
# Acceptance Integration IDs corresponding to Payment Channels
PAYMOB_INTEGRATION_ID_CARD=YOUR_PAYMOB_CREDIT_CARD_INTEGRATION_ID_HERE
PAYMOB_INTEGRATION_ID_WALLET=YOUR_PAYMOB_MOBILE_WALLET_INTEGRATION_ID_HERE
PAYMOB_INTEGRATION_ID_KIOSK=YOUR_PAYMOB_AMAN_MASARY_KIOSK_INTEGRATION_ID_HERE
# Paymob Credit Card Acceptance Iframe ID
PAYMOB_IFRAME_ID=YOUR_PAYMOB_CARD_IFRAME_ID_HERE

# 4. Multimodal AI Pre-Press Checks (Gemini API Configuration)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_FOR_ARTWORK_PREPRESS_AUDITS_HERE

# 5. Site Layout & Network Descriptors
# Base Public Address of the VPS (used to compute return URLs and redirects)
NEXT_PUBLIC_SITE_URL=http://your-vps-ip-or-domain.com
